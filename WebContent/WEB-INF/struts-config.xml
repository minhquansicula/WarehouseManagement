<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE struts-config PUBLIC
"-//Apache Software Foundation//DTD Struts Configuration 1.3//EN"
"http://struts.apache.org/dtds/struts-config_1_3.dtd">

<struts-config>

    <form-beans>

        <form-bean
            name="loginForm"
            type="form.LoginForm"/>

        <form-bean
            name="productForm"
            type="form.ProductForm"/>

        <form-bean
            name="supplierForm"
            type="form.SupplierForm"/>

    </form-beans>

    <action-mappings>
        <action
            path="/login"
            type="action.LoginAction"
            name="loginForm"
            scope="request"
            validate="false"
            input="/jsp/login.jsp">

            <forward
                name="success"
                path="/jsp/dashboard.jsp"/>

            <forward
                name="input"
                path="/jsp/login.jsp"/>

        </action>

        <action
            path="/dashboard"
            type="action.DashboardAction">

            <forward
                name="success"
                path="/jsp/dashboard.jsp"/>

        </action>

        <action
            path="/logout"
            type="action.LogoutAction">

            <forward
                name="success"
                path="/jsp/login.jsp"/>

        </action>
        
        <action
            path="/products"
            type="action.ProductAction"
            name="productForm"
            scope="request"
            validate="false"
            input="/jsp/product_form.jsp">

            <forward name="list" path="/jsp/product_list.jsp"/>
            <forward name="form" path="/jsp/product_form.jsp"/>

        </action>

        <action
            path="/suppliers"
            type="action.SupplierAction"
            name="supplierForm"
            scope="request"
            validate="false"
            input="/jsp/supplier_form.jsp">

            <forward name="list" path="/jsp/supplier_list.jsp"/>
            <forward name="form" path="/jsp/supplier_form.jsp"/>

        </action>
    </action-mappings>


</struts-config>