<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE struts-config PUBLIC
"-//Apache Software Foundation//DTD Struts Configuration 1.3//EN"
"http://struts.apache.org/dtds/struts-config_1_3.dtd">

<struts-config>

    <form-beans>

        <form-bean
            name="loginForm"
            type="form.LoginForm"/>

    </form-beans>

    <action-mappings>
        <action
            path="/login"
            type="action.LoginAction"
            name="loginForm"
            scope="request"
            validate="false"
            input="/jsp/login.jsp">

            <forward
                name="success"
                path="/jsp/dashboard.jsp"/>

            <forward
                name="input"
                path="/jsp/login.jsp"/>

        </action>

        <action
            path="/dashboard"
            type="action.DashboardAction">

            <forward
                name="success"
                path="/jsp/dashboard.jsp"/>

        </action>

        <action
            path="/logout"
            type="action.LogoutAction">

            <forward
                name="success"
                path="/jsp/login.jsp"/>

        </action>
    </action-mappings>


</struts-config>